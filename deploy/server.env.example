# 生产环境固定参数（Presto Bible @ 阿里云 ECS）
# 可复制字段到 deploy/deploy.env、deploy/publish.env、.env.production

# ── Git ──
GIT_REPO=https://github.com/Presto-bit/bible.git
GIT_REPO_SSH=git@github.com:Presto-bit/bible.git
GIT_REMOTE=origin
GIT_BRANCH=main

# ── 服务器 ──
DEPLOY_HOST=8.152.6.105
# 阿里云 SSH 用户（当前：presto）
DEPLOY_SSH=presto@8.152.6.105
DEPLOY_ROOT=/opt/bible
DEPLOY_APP_DIR=/opt/bible
APP_USER=presto

# ── 公网域名 ──
PUBLIC_DOMAIN=2sc.prestoai.cn
PUBLIC_WEB_URL=https://2sc.prestoai.cn
NEXT_PUBLIC_API_BASE=https://2sc.prestoai.cn
API_BASE_URL=https://2sc.prestoai.cn

# H5 独立子域，Next.js basePath 留空（勿设 /2sc）
NEXT_PUBLIC_BASE_PATH=

# ── DNS（在域名控制台添加）──
# 类型 A  主机记录 2sc  记录值 8.152.6.105  TTL 600

# ── 安全组（阿里云 ECS）──
# 入方向：TCP 22（SSH）、TCP 80、TCP 443
# 勿对公网开放 5433 / 8011 / 3000

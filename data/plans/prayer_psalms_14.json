    {"day": 8, "title": "荣耀归神", "scripture": {"ref": "诗篇 8:1", "book": "PSA", "chapter": 8, "verse": 1}, "acts": {"adoration": "称颂全地充满祂的荣耀。", "confession": "为窃取荣耀认罪。", "thanksgiving": "感谢祂记念人。", "supplication": "求祂让你生活归荣耀于祂。"}, "prompt": "今天哪件事可以只为祂荣耀？"},
    {"day": 9, "title": "公义审判", "scripture": {"ref": "诗篇 9:9", "book": "PSA", "chapter": 9, "verse": 9}, "acts": {"adoration": "称祂为受欺压者的高台。", "confession": "为对不公义冷漠认罪。", "thanksgiving": "感谢祂必伸冤。", "supplication": "为世上受苦的人代求。"}, "prompt": "谁的需要，今天你可以代祷？"},
    {"day": 10, "title": "不忘记", "scripture": {"ref": "诗篇 10:17", "book": "PSA", "chapter": 10, "verse": 17}, "acts": {"adoration": "称祂为听谦卑人。", "confession": "为觉得被忽视时的苦毒认罪。", "thanksgiving": "感谢祂看见你。", "supplication": "求祂安慰谦卑的心。"}, "prompt": "你是否感到被忽视？交给祂。"},

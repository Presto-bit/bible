# 复制为 deploy/deploy.env（勿提交 Git）
# cp deploy/deploy.env.example deploy/deploy.env

# Git 仓库（Presto-bit/bible）
GIT_REPO=https://github.com/Presto-bit/bible.git
GIT_REPO_SSH=git@github.com:Presto-bit/bible.git
GIT_REMOTE=origin
GIT_BRANCH=main

APP_USER=ubuntu
DEPLOY_ROOT=/opt/bible-app

# 1=首次部署时 apt 安装 docker.io
INSTALL_APT=1

# 1=部署前 git pull
GIT_PULL=1

# Git 远端（服务器 clone 后默认 origin）
# GIT_REMOTE=origin
# GIT_BRANCH=main
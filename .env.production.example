# 复制为 .env.production 后填写（勿提交 Git）
# cp .env.production.example .env.production

# ── 数据库（Compose 内 postgres 服务）──
DB_USER=bible
DB_PASSWORD=change-me-strong-password
DB_NAME=bible

# ── Web 构建 / 运行时 ──
# 浏览器访问 API 的公网基址（与 Nginx 反代一致，无尾斜杠）
NEXT_PUBLIC_API_BASE=https://www.prestoai.cn
# 发版脚本会自动写入 git 短 SHA；也可手动指定
NEXT_PUBLIC_APP_VERSION=

# ── API 密钥（写入 api 容器）──
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_TEXT_MODEL=deepseek-v4-flash

RAG_EMBEDDING_PROVIDER=api
RAG_EMBEDDING_API_KEY=
RAG_EMBEDDING_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/embeddings
RAG_EMBEDDING_MODEL=text-embedding-v4

AI_GUEST_DAILY_LIMIT=10

# ── 认证（生产建议接 orchestrator；无则关闭 dev 头）──
ORCHESTRATOR_BASE_URL=
AUTH_DEV_ALLOW_USER_HEADER=0

API_BASE_URL=https://www.prestoai.cn
PUBLIC_WEB_URL=https://www.prestoai.cn/2sc

# ── Docker 构建（可选）──
# 海外机器可设 NODE_BASE_IMAGE=node:20-alpine
# NODE_BASE_IMAGE=swr.cn-north-4.myhuaweicloud.com/ddn-k8s/docker.io/library/node:20-alpine
COMPOSE_BUILD_PULL=1

# ── 本地一键 SSH 发布（scripts/publish.sh，勿放密钥到本文件）──
# DEPLOY_SSH=ubuntu@your-ecs-ip
# DEPLOY_APP_DIR=/opt/bible-app

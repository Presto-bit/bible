# API 环境变量示例（复制为 services/api/.env 并填入真实密钥）

DATABASE_URL=postgresql://bible:bible@localhost:5432/bible

# ── LLM（DeepSeek，OpenAI 兼容）──
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_TEXT_MODEL=deepseek-v4-flash

# ── Embedding（阿里云 DashScope，OpenAI 兼容）──
RAG_EMBEDDING_PROVIDER=api
RAG_EMBEDDING_API_KEY=
RAG_EMBEDDING_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/embeddings
RAG_EMBEDDING_MODEL=text-embedding-v4

# ── RAG 切块与检索 ──
RAG_CHUNK_CHARS=900
RAG_CHUNK_OVERLAP=70
BIBLE_RAG_INDEX_STRATEGY=per_chapter
RAG_HYBRID_VECTOR_WEIGHT=0.55
RAG_HYBRID_KEYWORD_WEIGHT=0.45
RAG_CANDIDATE_LIMIT_BOOK=200
RAG_CANDIDATE_LIMIT_CHAPTER=120
RAG_CANDIDATE_LIMIT_FALLBACK=800
RAG_QUERY_EMBED_CACHE_TTL=300
NOTE_RAG_PER_CHAPTER_MIN_CHUNKS=2
NOTE_RAG_MAX_CHUNKS_ABS=512
BIBLE_RAG_VECTOR_BACKEND=auto

# ── AI 额度（游客）──
AI_GUEST_DAILY_LIMIT=10

CORS_ORIGINS=https://2sc.prestoai.cn,http://localhost:3000,http://127.0.0.1:3000

# ── 认证 ──
# 本地调试可设 1；生产必须 0（误拷到生产会使裸 X-User-Code 可冒充）
AUTH_DEV_ALLOW_USER_HEADER=0
SESSION_TOKEN_SECRET=dev-session-secret-change-me
ADMIN_PHONE=
ADMIN_PASSWORD=
ADMIN_TOKEN_SECRET=dev-admin-token-secret-change-me

# ── 部署域名 ──
API_BASE_URL=https://2sc.prestoai.cn
PUBLIC_WEB_URL=https://2sc.prestoai.cn

# ── Web Push（VAPID，可选）──
# 生成：npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@prestoai.cn
# 定时任务鉴权（/push/cron/tick、/social/cron/prune-inactive-groups）
PUSH_CRON_SECRET=

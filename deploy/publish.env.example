# 复制为 deploy/publish.env（勿提交 Git）
# cp deploy/publish.env.example deploy/publish.env

# Git 仓库
GIT_REPO=https://github.com/Presto-bit/bible.git
GIT_REPO_SSH=git@github.com:Presto-bit/bible.git

# ECS SSH，例：ubuntu@47.96.x.x
DEPLOY_SSH=ubuntu@YOUR_ECS_IP

# 服务器上仓库路径（与 deploy/deploy.env 的 DEPLOY_ROOT 一致）
DEPLOY_APP_DIR=/opt/bible-app

REMOTE=origin
BRANCH=main

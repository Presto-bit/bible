    {"day": 5, "title": "清晨转向", "scripture": {"ref": "诗篇 5:3", "book": "PSA", "chapter": 5, "verse": 3}, "acts": {"adoration": "称颂清晨的同在。", "confession": "为匆忙开始一天认罪。", "thanksgiving": "感谢新的一天从祂开始。", "supplication": "求祂引导今天的脚步。"}, "prompt": "今天第一件事，能否先转向祂？"},
    {"day": 6, "title": "义人呼求", "scripture": {"ref": "诗篇 6:9", "book": "PSA", "chapter": 6, "verse": 9}, "acts": {"adoration": "称祂为听哀求的主。", "confession": "为隐藏眼泪认罪。", "thanksgiving": "感谢祂不轻看眼泪。", "supplication": "把伤心事带到祂面前。"}, "prompt": "有什么伤，你还没对神说过？"},

# 复制为 .env.production 后填写密钥（勿提交 Git）
# cp .env.production.example .env.production

# ── 数据库 ──
DB_USER=bible
DB_PASSWORD=change-me-strong-password
DB_NAME=bible

# ── 公网（2sc.prestoai.cn 独立子域）──
NEXT_PUBLIC_BASE_PATH=
NEXT_PUBLIC_API_BASE=https://2sc.prestoai.cn
NEXT_PUBLIC_APP_VERSION=

# ── API 密钥 ──
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_TEXT_MODEL=deepseek-v4-flash

RAG_EMBEDDING_PROVIDER=api
RAG_EMBEDDING_API_KEY=
RAG_EMBEDDING_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/embeddings
RAG_EMBEDDING_MODEL=text-embedding-v4

AI_GUEST_DAILY_LIMIT=10

ORCHESTRATOR_BASE_URL=
# 生产必须为 0：禁止裸 X-User-Code 冒充
AUTH_DEV_ALLOW_USER_HEADER=0
# 本机会话令牌密钥（必填；勿用弱口令）
SESSION_TOKEN_SECRET=change-me-session-token-secret

# 管理员后台（口令勿用 123456；未配置则无法登录后台）
ADMIN_PHONE=
ADMIN_PASSWORD=
ADMIN_TOKEN_SECRET=change-me-admin-token-secret
CORS_ORIGINS=https://2sc.prestoai.cn

API_BASE_URL=https://2sc.prestoai.cn
PUBLIC_WEB_URL=https://2sc.prestoai.cn

# ── Web Push（VAPID，可选）──
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@prestoai.cn
PUSH_CRON_SECRET=

COMPOSE_BUILD_PULL=1

# Web 映射到本机端口（生产默认 3002，避免与宝塔/其他 Node 占用的 3000 冲突）
WEB_HOST_PORT=3002

# ── 本地一键发布 ──
# DEPLOY_SSH=presto@8.152.6.105
# DEPLOY_APP_DIR=/opt/bible
